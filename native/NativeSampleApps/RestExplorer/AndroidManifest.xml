<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:versionCode="1"
	android:versionName="1.0"
	android:installLocation="internalOnly">

	<application android:icon="@drawable/sf__icon"
	    android:label="@string/app_name"
		android:name=".RestExplorerApp"
		android:manageSpaceActivity="com.salesforce.androidsdk.ui.ManageSpaceActivity"
		android:enableOnBackInvokedCallback="true"
        tools:targetApi="tiramisu">

		<!-- Vector DB spike Phase 4: LiteRT-LM uses these native libs when
		     running the LLM on the GPU backend. Both are non-required so
		     devices that lack OpenCL (typical emulators) still install. -->
		<uses-native-library android:name="libvndksupport.so" android:required="false" />
		<uses-native-library android:name="libOpenCL.so" android:required="false" />

		<!-- Launcher screen -->
		<activity android:name=".ExplorerActivity"
			android:theme="@style/SalesforceSDK_Fullscreen"
			android:exported="true">

			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>

			<intent-filter>
				<action android:name="android.intent.action.VIEW" />
				<category android:name="android.intent.category.DEFAULT" />
			</intent-filter>

		</activity>

		<!-- Vector DB spike Phase 4: RAG demo activity.
		     exported=true so developers can launch directly via
		         adb shell am start -n com.salesforce.samples.restexplorer/.rag.RagActivity
		     without going through the Salesforce login flow. The activity only
		     reads/writes a local SmartStore soup named "ragDocs" and calls
		     MediaPipe Tasks on-device — no remote interaction, no credentials. -->
		<activity android:name=".rag.RagActivity"
			android:label="@string/rag_title"
			android:theme="@style/SalesforceSDK"
			android:exported="true" />

		<!-- Login activity -->
		<!--
            To enable browser based authentication, uncomment the lines below and replace
            'scheme', 'host' and 'path' with their corresponding values from your connected app.

            For example, if the callback URL of your connected app is
            "testsfdc:///mobilesdk/detect/oauth/done",
            'scheme' would be "testsfdc", 'host' would be "*" since it doesn't exist, and
            'path' would be "/mobilesdk/detect/oauth/done".

            If the callback URL is "sfdc://login.salesforce.com/oauth/done",
            'scheme' would be "sfdc", 'host' would be "login.salesforce.com",
            and 'path' would be "/oauth/done".
        -->
        <activity android:name="com.salesforce.androidsdk.ui.LoginActivity"
            android:theme="@style/SalesforceSDK"
            android:launchMode="singleTask"
			android:exported="true">

            <intent-filter>
                <data android:scheme="testsfdc"
                    android:host="*"
                    android:path="/mobilesdk/detect/oauth/done" />
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

	</application>
</manifest>
